package Graph;


import java.util.ArrayList;
import java.util.Scanner;

public class DetectCycleAndCountVisits {
    public static boolean dfs(int node, int parent, boolean[] visited, ArrayList<ArrayList<Integer>> graph , int[] count){
        visited[node] = true;
        count[0]++;

        for(int neig : graph.get(node)){
            if(!visited[neig]){
                if(dfs(neig , node , visited,graph,count)){
                    return true;
                }
            }
            else if(neig != parent){
                return true; //cycle detected
            }
        }
        return false; //no cycle
    }
    public static void main(String[] agrs){
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int e = sc.nextInt();
        ArrayList<ArrayList<Integer>> grf = new ArrayList<>();

        for(int i=0 ; i<n ; i++){
            grf.add(new ArrayList<>());
        }

        for(int i=0 ;i<e ; i++){
            int u = sc.nextInt();
            int v = sc.nextInt();

            grf.get(u).add(v);
            grf.get(v).add(u);

        }
        boolean[] visited = new boolean[n];
        for(int i=0;i<n;i++){
            if(!visited[i]){
                int[] count = new int[1];
                boolean hasCycle = dfs(i , -1 , visited , grf ,count);
                System.out.println("Component starting at " + i);
                System.out.println("Nodes = " + count[0]);
                System.out.println("Cycle present = " + hasCycle);
                System.out.println();
            }
        }

    }
}
